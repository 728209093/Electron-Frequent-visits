{
  "name": "traffic-booster",
  "version": "1.0.0",
  "description": "A desktop application for automated website traffic boosting with proxy rotation and behavior simulation",
  "main": "dist/main/main/index.js",
  "homepage": "./",
  "scripts": {
    "dev": "concurrently --prefix none \"npm run dev:main\" \"npm run dev:renderer\"",
    "dev:main": "cross-env NODE_ENV=development tsc --watch --project tsconfig.main.json",
    "dev:renderer": "vite",
    "build": "npm run build:main && npm run build:renderer",
    "build:main": "tsc --project tsconfig.main.json",
    "build:renderer": "vite build",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "start": "electron dist/main/main/index.js",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^1.9.7",
    "antd": "^5.11.0",
    "axios": "^1.6.2",
    "bullmq": "^5.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "echarts": "^5.4.3",
    "express": "^4.18.2",
    "i18next": "^23.7.0",
    "puppeteer": "^21.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-i18next": "^13.5.0",
    "react-redux": "^8.1.3",
    "sqlite3": "^5.1.6",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^20.9.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/uuid": "^9.0.7",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.1",
    "cross-env": "^7.0.3",
    "electron": "^27.0.0",
    "electron-builder": "^24.6.4",
    "less": "^4.2.0",
    "less-loader": "^12.2.0",
    "postcss": "^8.4.31",
    "tailwindcss": "^3.3.6",
    "tsc-alias": "^1.8.8",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.2.2",
    "vite": "^5.0.0"
  },
  "author": "Your Name",
  "license": "MIT"
}
