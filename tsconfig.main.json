{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "rootDir": "./src",
    "outDir": "./dist/main",
    "module": "commonjs",
    "noEmit": false,
    "lib": ["ES2020", "DOM"],
    "target": "ES2020",
    "moduleResolution": "node",
    "allowImportingTsExtensions": false
  },
  "include": ["src/main", "src/shared"],
  "exclude": ["src/renderer"]
}
